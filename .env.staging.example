# =============================================================================
# ステージング環境用 環境変数
# 
# ローカルでステージングDBに接続して開発する場合に使用
# 
# 使い方:
#   1. cp .env.staging.example .env.staging
#   2. Supabase Dashboard からステージングプロジェクトの Anon Key を取得
#   3. VITE_SUPABASE_ANON_KEY に貼り付け
#   4. npm run dev:staging
# =============================================================================

# ステージングプロジェクト (lavutzztfqbdndjiwluc)
VITE_SUPABASE_URL=https://lavutzztfqbdndjiwluc.supabase.co
VITE_SUPABASE_ANON_KEY=<Supabase Dashboard → Settings → API → anon key>

VITE_APP_ENV=staging
VITE_DEBUG=true
