# =============================================================================
# ローカル開発環境用 環境変数
# 
# Supabase Local を使用する場合の設定
# 
# 使い方:
#   1. cp .env.local.example .env.local
#   2. Docker 起動後に supabase start（既定 JWT なら .example の anon で接続可）
#   3. JWT を変えた場合は表示された anon を VITE_SUPABASE_ANON_KEY に貼る
#   4. npm run dev
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Local 設定
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=http://localhost:54321

# ローカル既定 JWT（secret 未変更の `supabase start` と一致）。変えた場合は `supabase status` の anon を貼る
# クラウド利用時は VITE_SUPABASE_URL を合わせ、下記を Dashboard のキーに差し替え
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# -----------------------------------------------------------------------------
# アプリケーション設定
# -----------------------------------------------------------------------------
VITE_APP_ENV=local
VITE_DEBUG=true

# -----------------------------------------------------------------------------
# 外部サービス連携（ローカルでは不要な場合はコメントアウト）
# -----------------------------------------------------------------------------
# VITE_GOOGLE_APPS_SCRIPT_URL=
