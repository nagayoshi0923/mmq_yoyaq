# ============================================================
# バックエンド API (/api/*) 用の環境変数
# Vercel の Environment Variables に設定する（フロントには絶対含めない）
# ============================================================

# Supabase URL（フロントの VITE_SUPABASE_URL と同じ値）
SUPABASE_URL=https://your-project.supabase.co

# service_role キー: RLS を完全にバイパスするためサーバー側だけに置く
# Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# 本番の CORS 許可オリジン（例: https://mmq.jp）
# 未設定の場合は localhost のみ許可される
ALLOWED_ORIGIN=https://your-production-domain.com

# ============================================================
# フロントエンド用の環境変数
# ============================================================

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
# 推奨: Publishable key（sb_publishable_...）
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
#
# 互換用（Legacy API Keysが有効な場合のみ）: anon key (JWT / eyJ...)
# Legacy API Keys を Disable しているプロジェクトでは使用できません。
VITE_SUPABASE_ANON_KEY=your_legacy_anon_key_here

# Development Configuration
VITE_APP_ENV=development
# Vite の待受: 未設定時は 127.0.0.1（起動が安定）。LAN 公開が必要なときだけ all
# VITE_DEV_HOST=all
# 詳細デバッグ（既定ではオフ推奨。true にすると logger.log / 一部の詳細ログが増える）
# VITE_DEBUG=true
# 認証フローのコンソールトレース（AuthContext）。通常は不要。true のときのみ [auth] ログが出る
# VITE_AUTH_DEBUG=true
# 貸切予約管理の詳細トレース（件数・予約ごとの候補日など）。true のときのみ [private-booking] ログが出る
# VITE_PRIVATE_BOOKING_DEBUG=true

# Email Configuration
# メール送信は Resend API + 独自ドメイン (mmq.game) を使用
# ⚠️ AWS SESは完全に廃止されました
# 
# 1. Edge Functions経由のメール（予約確認、リマインダー、一斉送信など）:
#    - Supabase Secrets で RESEND_API_KEY を設定
#    - 送信元: noreply@mmq.game
#
# 2. Supabase Auth関連のメール（パスワードリセット、サインアップ確認）:
#    - Supabase Dashboard → Settings → Auth → SMTP Settings で設定
#    - Host: smtp.resend.com
#    - Port: 587
#    - Username: resend
#    - Password: [RESEND_API_KEY と同じ値]
#    - Sender: noreply@mmq.game
#
# 詳細: EMAIL_SETUP.md または RESEND_QUICK_SETUP.md を参照
# 全シーン: EMAIL_USAGE_SCENARIOS.md を参照
